# === LUMEN v2 API Keys ===
OPENROUTER_API_KEY=sk-or-...

# Optional: database-specific APIs
NCBI_API_KEY=               # PubMed E-utilities (higher rate limit)
ELSEVIER_API_KEY=           # Scopus + ScienceDirect
SEMANTIC_SCHOLAR_API_KEY=   # Semantic Scholar (optional, higher rate limit)

# === Database Toggles ===
ENABLE_PUBMED=true
ENABLE_EUROPEPMC=true
ENABLE_SCOPUS=false         # Requires Elsevier API key
ENABLE_CROSSREF=true
ENABLE_OPENALEX=true

# === Per-Phase Token Budgets (USD) ===
TOKEN_BUDGET_PHASE1=2.00
TOKEN_BUDGET_PHASE3_0=0.50
TOKEN_BUDGET_PHASE3_TA=8.00
TOKEN_BUDGET_PHASE3_FT=5.00
TOKEN_BUDGET_PHASE4=15.00
TOKEN_BUDGET_PHASE5=2.00
TOKEN_BUDGET_PHASE6=5.00
TOKEN_BUDGET_QUALITY_ASSESSMENT=5.00
TOKEN_BUDGET_PDF_CONVERSION=10.00
